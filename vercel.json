{
  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    }
  ],
  "functions": {
    "api/ideogram-generate.js": {
      "maxDuration": 60
    },
    "api/design-visualiser.js": {
      "maxDuration": 60
    },
    "api/strategic-plan-generate.js": {
      "includeFiles": "node_modules/docx/**"
    },
    "api/generate-social-content.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/archive-old-tenders",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/scan-worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/ea-purge",
      "schedule": "0 16 * * 6"
    },
    {
      "path": "/api/scan-scheduler",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/social-publisher",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/auth/oauth-callback.js"
    },
    {
      "source": "/api/auth/microsoft/callback",
      "destination": "/api/auth/oauth-callback.js"
    },
    {
      "source": "/tools",
      "destination": "/tools.html"
    },
    {
      "source": "/industry",
      "destination": "/industry-select.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing-page.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/forgot-password",
      "destination": "/forgot-password.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/activate",
      "destination": "/panel-auth.html"
    },
    {
      "source": "/library",
      "destination": "/content-library.html"
    },
    {
      "source": "/library/settings",
      "destination": "/cl-settings.html"
    },
    {
      "source": "/strategy",
      "destination": "/strategic-plan.html"
    },
    {
      "source": "/chatbot",
      "destination": "/chatbot.html"
    },
    {
      "source": "/chatbot/settings",
      "destination": "/chatbot-settings.html"
    },
    {
      "source": "/email",
      "destination": "/email-assistant.html"
    },
    {
      "source": "/email/settings",
      "destination": "/email-assistant-settings.html"
    },
    {
      "source": "/news",
      "destination": "/news-digest.html"
    },
    {
      "source": "/news/settings",
      "destination": "/news-digest-settings.html"
    },
    {
      "source": "/social",
      "destination": "/social.html"
    },
    {
      "source": "/social/settings",
      "destination": "/social-settings.html"
    },
    {
      "source": "/design",
      "destination": "/design-viz.html"
    },
    {
      "source": "/design/settings",
      "destination": "/design-viz-settings.html"
    },
    {
      "source": "/account",
      "destination": "/account.html"
    },
    {
      "source": "/panel",
      "destination": "/panel.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms-of-service.html"
    }
  ]
}