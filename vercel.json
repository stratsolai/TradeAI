  "rewrites": [
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/auth/oauth-callback.js"
    },
    {
      "source": "/api/auth/microsoft/callback",
      "destination": "/api/auth/oauth-callback.js"
    },
    {
      "source": "/api/auth/google-drive/callback",
      "destination": "/api/auth/oauth-callback.js"
    },
    {
      "source": "/tools",
